GROK_API_URL=http://your-model-service/v1/chat/completions
GROK_MODEL=grok-4.20-fast
GROK_API_KEY=replace-with-your-backend-key
SESSION_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_APP_NAME=AIGC Text Polish
BOOTSTRAP_ADMIN_CARD=REPLACE-WITH-YOUR-FIRST-ADMIN-CARD

# 单容器 Docker 部署保持为空，让前端请求同域 API。
NEXT_PUBLIC_API_BASE_URL=

# 允许访问后端 API 的前端来源，多个用英文逗号分隔。
# 单容器同域部署可留空。
CORS_ORIGINS=

PORT=3000
HOSTNAME=0.0.0.0
